{
  "domain_id": "synthetic",
  "baseline_policy": {
    "x": 0.0,
    "y": 0.0,
    "noise": 0.1
  },
  "optimizer_id": "random",
  "objective": {
    "name": "score",
    "direction": "maximize"
  },
  "constraints": [
    {
      "name": "latency_ms",
      "operator": "<=",
      "threshold": 120.0
    },
    {
      "name": "error_rate",
      "operator": "<=",
      "threshold": 0.2
    }
  ],
  "window_config": {
    "type": "sample",
    "sample_count": 250,
    "timeout_seconds": 60
  }
}
